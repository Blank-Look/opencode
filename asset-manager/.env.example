# Server
PORT=3000
NODE_ENV=development

# Azure AD App Registration (for Microsoft Graph API access)
# Create an App Registration in Azure AD with these API permissions:
#   - Group.Read.All
#   - Application.Read.All
#   - Sites.Read.All
#   - ThreatIndicators.Read.All (Defender)
#   - ServicePrincipalEndpoint.Read.All (Power Automate)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Session secret for dashboard auth
SESSION_SECRET=change-me-to-a-random-string

# Database path (default: ./data/asset-manager.db)
DATABASE_PATH=./data/asset-manager.db
